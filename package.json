{
  "name": "afaq-attendance-bridge",
  "version": "0.1.1",
  "description": "Afaq Attendance Bridge — outbound sync from Hikvision devices to central Afaq Finance",
  "private": false,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "bin": {
    "afaq-attendance-bridge": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js run",
    "activate": "node dist/main.js activate",
    "status": "node dist/main.js status",
    "test": "npm run build && node --test test/bridge.test.js",
    "package:fetch": "pkg-fetch node18-win-x64",
    "package:exe": "pkg dist/main.js --targets node18-win-x64 --output dist-packages/build/AfaqAttendanceBridge.exe --options max_old_space_size=4096",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  },
  "pkg": {
    "assets": [
      "package.json"
    ],
    "outputPath": "dist-packages/build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pkg": "^5.8.1",
    "pkg-fetch": "^3.4.3",
    "typescript": "^5.7.2"
  }
}
